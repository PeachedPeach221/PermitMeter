{
  "manifest_version": 3,
  "name": "PermitMeter",
  "version": "1.0.0",
  "description": "Analyze Chrome extension permissions and risk score without installing them.",
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://clients2.google.com/*",
    "https://clients2.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
